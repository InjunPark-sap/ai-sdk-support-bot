{
  "name": "sap-ai-sdk-support-bot",
  "version": "0.0.1",
  "description": "SAP AI SDK dogfooding support bot — Context7 + GH MCP + @sap-ai-sdk/langchain",
  "type": "module",
  "scripts": {
    "start": "tsx --env-file=.env src/cli.ts",
    "serve": "tsx --env-file=.env src/server.ts",
    "build": "tsc --noEmit",
    "refresh": "tsx --env-file=.env scripts/refresh-embeddings.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@sap-ai-sdk/langchain": "^2.13.0",
    "@sap-ai-sdk/orchestration": "^2.13.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
